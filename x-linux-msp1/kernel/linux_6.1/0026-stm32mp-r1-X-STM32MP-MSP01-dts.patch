From d41eae63647af07117c3223ca1cbec5b4d6a0142 Mon Sep 17 00:00:00 2001
From: Prashant Pandey <prashant-mpa.pandey@st.com>
Date: Mon, 15 Jan 2024 22:16:26 +0530
Subject: [PATCH] stm32mp-r1-X-STM32MP-MSP01-dts

---
 arch/arm/boot/dts/stm32mp135f-dk.dts  | 83 +++++++++++++++++++++++++
 arch/arm/boot/dts/stm32mp157f-dk2.dts | 88 +++++++++++++++++++++++++++
 2 files changed, 171 insertions(+)

diff --git a/arch/arm/boot/dts/stm32mp135f-dk.dts b/arch/arm/boot/dts/stm32mp135f-dk.dts
index bee689f2e..3e7b1e3a9 100644
--- a/arch/arm/boot/dts/stm32mp135f-dk.dts
+++ b/arch/arm/boot/dts/stm32mp135f-dk.dts
@@ -417,6 +417,89 @@ goodix: goodix-ts@5d {
 		touchscreen-size-y = <272>;
 		status = "okay" ;
 	};
+
+	 /*X-STM32MP-MSP01: NOTE:
+	 *
+	 *  1) For STM32MP-MSP01 DIL24 the valid address for IMU
+	 *     is 0x6a (0x6b already used by on board IMU)
+	 *  2) CS and SDO/SDA0 pins are left unconnected by
+	 *     default so you need to put them at correct value
+	 *     (VDDIO/GND) accordingly
+	 *  3) INT1 need to be pulled-down to avoid I3C only
+	 *     mode at boot time when AP int line is not already
+	 *     configured by OS
+	 *  4) uses GPIO 22 / PG15 on X-STM32MP-MSP01 for DIL24
+	 *
+	 * ism330dhcx - IMU, add 0x6b, int2 on ISM330DHC_INT2 (PB12)
+	 * iis2mdc -    MAG40, add 0x1e, ind-drdy on IIS2MDC_INT_DRDY (PA8)
+	 * iis2dlpc -   Acc, add 0x19, int1 on IIS2DLPC_INT1 (PF3), int2
+	 *              on IIS2DLPC_INT2 (PI5)
+	 * lps22hh -    Press, add 0x5d, int-drdy on LPS22HH_INT_DRDY (PG8)
+	 * stts22h -  	Temp, add 0x38, alert/int on STTS22H_INT (PG2)
+	 */
+
+	/* ISM330DHCX 6 Axis IMU */
+	st_ism330dhcx_X_STM32MP_MSP01@6b {
+		compatible = "st,ism330dhcx";
+
+		reg =<0x6b>;
+		st,int-pin = <2>;
+
+		/* STM32MP135F-DK + X-STM32MP-MSP01: ISM330DHC_INT2 --> PB0 */
+		interrupt-parent = <&gpiob>;
+		interrupts = <0 IRQ_TYPE_LEVEL_HIGH>;
+
+		status = "okay";
+	};
+
+	/* IIS2MDC 3 Axis Magnetometer */
+	iis2mdc_magn_X_STM32MP_MSP01@1e {
+		compatible = "st,iis2mdc_magn";
+		reg = <0x1e>;
+
+		/* STM32MP135F-DK + X-STM32MP-MSP01: IIS2MDC_INT_DRDY --> PB1 */
+		interrupt-parent = <&gpiob>;
+		interrupts = <1 IRQ_TYPE_EDGE_RISING>;
+
+		status = "okay";
+	};
+
+	/* IIS2DLPC 3 Axis Accelerometer */
+	iis2dlpc_X_STM32MP_MSP01@19 {
+		compatible = "st,iis2dlpc";
+		reg = <0x19>;
+
+		/* STM32MP135F-DK + X-STM32MP-MSP01: IIS2DLPC_INT1 --> PF10 */
+		st,drdy-int-pin = <1>;
+		interrupt-parent = <&gpiof>;
+		interrupts = <10 IRQ_TYPE_EDGE_RISING>;
+
+		status = "okay";
+	};
+
+	/* LPS22HH Pressure Sensor */
+	lps22hh_X_STM32MP_MSP01@5d {
+		compatible = "st,lps22hh";
+		reg = <0x5d>;
+
+		/* STM32MP135F-DK + X-STM32MP-MSP01: LPS22HH_INT_DRDY --> PC2 */
+		interrupt-parent = <&gpioc>;
+		interrupts = <2 IRQ_TYPE_EDGE_RISING>;
+
+		status = "disabled";
+	};
+
+	/* STTS22H Pressure Sensor */
+	stts22h_temp_X_STM32MP_MSP01@38 {
+		compatible = "st,stts22h";
+		reg = <0x38>;
+
+		/* STM32MP135F-DK + X-STM32MP-MSP01: GPIO_STTS22H_INT --> PE6 */
+		interrupt-parent = <&gpioe>;
+		interrupts = <6 IRQ_TYPE_EDGE_RISING>;
+
+		status = "okay";
+	};
 };
 
 &ltdc {
diff --git a/arch/arm/boot/dts/stm32mp157f-dk2.dts b/arch/arm/boot/dts/stm32mp157f-dk2.dts
index c07a360f6..a43b028fe 100644
--- a/arch/arm/boot/dts/stm32mp157f-dk2.dts
+++ b/arch/arm/boot/dts/stm32mp157f-dk2.dts
@@ -100,6 +100,94 @@ touchscreen@38 {
 	};
 };
 
